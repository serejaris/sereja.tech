{{- $index := slice -}}
{{- range (where .Site.RegularPages "Section" "blog").ByDate.Reverse -}}
{{- $index = $index | append (dict "title" .Title "url" .RelPermalink "date" (.Date.Format "2 Jan 2006") "tags" (.Params.tags | default slice) "description" (.Description | plainify) "content" .Plain) -}}
{{- end -}}
{{- $index | jsonify -}}