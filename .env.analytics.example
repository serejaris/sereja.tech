# PostHog Personal API key for read access (Query API).
# Create once at https://us.posthog.com/settings/user-api-keys
# Scopes: "Query Read" + "Project Read". Shown only once — copy it here.
# Then: cp .env.analytics.example .env.analytics  and paste the key.
POSTHOG_PERSONAL_API_KEY=phx_replace_me
